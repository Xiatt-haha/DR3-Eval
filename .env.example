# API for Google Search (recommend)
SERPER_API_KEY=your_serper_key
SERPER_BASE_URL="https://google.serper.dev"

# API for Web Scraping (recommend)
JINA_API_KEY=your_jina_key
JINA_BASE_URL="https://r.jina.ai"

# API for Linux Sandbox (recommend)
E2B_API_KEY=your_e2b_key

# API for LLM-as-Judge (for benchmark testing)
OPENAI_API_KEY=your_openai_key
OPENAI_BASE_URL="https://api.openai.com/v1"

# Must have for minimal agent get started
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# API for Open-Source Audio Transcription Tool (for benchmark testing)
WHISPER_MODEL_NAME="openai/whisper-large-v3-turbo"
WHISPER_API_KEY=your_whisper_key
WHISPER_BASE_URL="https://your_whisper_base_url/v1"

# Enhanced Audio Tool Configuration
# Provider options: openai_whisper, whisper_os, qwen_audio, gpt4o_audio, gemini_audio
# Using gemini_audio with Gemini 2.5 Flash which supports audio_url format
AUDIO_PROVIDER=gemini_audio
GEMINI_AUDIO_API_KEY=your_gemini_audio_key
GEMINI_AUDIO_BASE_URL="https://generativelanguage.googleapis.com/v1beta"
GEMINI_AUDIO_MODEL="gemini-2.5-flash-preview-05-20"
GEMINI_AUDIO_MAX_SIZE_MB=5.5
AUDIO_ENABLE_MULTI_TURN=false

# API for Open-Source VQA Tool (for benchmark testing)
VISION_MODEL_NAME="gpt-5"
VISION_API_KEY=your_vision_key
VISION_BASE_URL="https://api.openai.com/v1"

# API for Open-Source Reasoning Tool (for benchmark testing)
REASONING_MODEL_NAME="Qwen/Qwen3-235B-A22B-Thinking-2507"
REASONING_API_KEY=your_reasoning_key
REASONING_BASE_URL="https://your_reasoning_base_url/v1/chat/completions"

# API for Claude Sonnet 3.7 as Commercial Tools (optional)
ANTHROPIC_API_KEY=your_anthropic_key
ANTHROPIC_BASE_URL="https://api.anthropic.com"

# API for Sougou Search (optional)
TENCENTCLOUD_SECRET_ID=your_tencent_cloud_secret_id
TENCENTCLOUD_SECRET_KEY=your_tencent_cloud_secret_key

# Enhanced VQA Tool Configuration
VLLM_PROVIDER=openai
VLLM_API_KEY=your_vllm_key
VLLM_BASE_URL="https://api.openai.com/v1"
VLLM_MODEL="gpt-4.1"
VLLM_ENABLE_MULTI_TURN=true
# Legacy names (for backward compatibility)
VLLM_OPENAI_API_KEY=your_vllm_openai_key
VLLM_OPENAI_BASE_URL="https://api.openai.com/v1"
VLLM_OPENAI_MODEL="gpt-4.1"

# Progressive Memory Configuration

# Enhanced Video Tool Configuration
# Using frames-based analysis (extracts keyframes and uses VQA model)
VIDEO_PROVIDER=frames
# Frames provider uses VLLM_OPENAI_* settings by default, or you can override:
# FRAMES_VIDEO_API_KEY="your_key"
# FRAMES_VIDEO_BASE_URL="your_base_url"
# FRAMES_VIDEO_MODEL="gpt-4o"
FRAMES_VIDEO_COUNT=8
FRAMES_VIDEO_MAX_SIZE=512
VIDEO_ENABLE_MULTI_TURN=false
